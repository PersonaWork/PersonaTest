generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  privyId       String        @unique
  email         String        @unique
  username      String        @unique
  displayName   String?
  hasSetUsername Boolean       @default(false)
  walletAddress String?       @unique
  usdcBalance     Float         @default(0)
  lastGasFundedAt DateTime?
  preferences     Json?
  referralCode    String?       @unique
  referredById    String?
  referredBy      User?         @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]        @relation("Referrals")
  createdAt       DateTime      @default(now())
  holdings      Holding[]
  messages      Message[]
  payouts       Payout[]
  buyerTxns     Transaction[] @relation("BuyerTransactions")
  sellerTxns    Transaction[] @relation("SellerTransactions")
  limitOrders   LimitOrder[]

  @@index([privyId])
  @@index([email])
  @@index([referralCode])
}

model Character {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  description     String
  thumbnailUrl    String?
  personality     Json
  actions         Json
  environment     Json
  totalShares     Int              @default(10000)
  sharesIssued    Int              @default(0)
  currentPrice    Float            @default(0.00001)
  marketCap       Float            @default(0)
  phase           String           @default("BONDING_CURVE") // "BONDING_CURVE" or "GRADUATED"
  poolBalance     Float            @default(0) // USDC liquidity pool from bonding curve buys
  graduatedAt     DateTime?        // When character graduated to free market
  launchAt        DateTime?
  isLaunched      Boolean          @default(false)
  tiktokHandle    String?
  instagramHandle String?
  createdAt       DateTime         @default(now())
  holdings        Holding[]
  posts           Post[]
  messages        Message[]
  events          CharacterEvent[]
  transactions    Transaction[]
  animationClips  AnimationClip[]
  payouts         Payout[]
  limitOrders     LimitOrder[]

  @@index([slug])
  @@index([isLaunched])
  @@index([createdAt])
  @@index([phase])
}

model Holding {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  shares      Int
  avgBuyPrice Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])

  @@unique([userId, characterId])
  @@index([userId])
  @@index([characterId])
}

model Post {
  id          String    @id @default(cuid())
  characterId String
  platform    String
  videoUrl    String
  caption     String
  revenue     Float     @default(0)
  views       Int       @default(0)
  likes       Int       @default(0)
  paidOut     Boolean   @default(false)
  postedAt    DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id])
  payouts     Payout[]

  @@index([characterId])
  @@index([postedAt])
}

model Message {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  content     String
  role        String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])

  @@index([userId])
  @@index([characterId])
  @@index([createdAt])
}

model CharacterEvent {
  id          String    @id @default(cuid())
  characterId String
  actionId    String
  isRare      Boolean   @default(false)
  triggeredAt DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id])

  @@index([characterId])
  @@index([triggeredAt])
}

model Transaction {
  id            String    @id @default(cuid())
  buyerId       String?
  sellerId      String?
  characterId   String?
  shares        Int
  pricePerShare Float
  total         Float
  platformFee   Float     @default(0)
  type          String
  txHash        String?   @unique   // On-chain tx hash for deposits/withdrawals (dedup key)
  createdAt     DateTime  @default(now())
  character      Character?  @relation(fields: [characterId], references: [id])
  buyer          User?       @relation("BuyerTransactions", fields: [buyerId], references: [id])
  seller         User?       @relation("SellerTransactions", fields: [sellerId], references: [id])
  limitOrderFill LimitOrder?

  @@index([buyerId])
  @@index([sellerId])
  @@index([characterId])
  @@index([createdAt])
}

model Payout {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  postId      String
  amount      Float
  paidAt      DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
  post        Post      @relation(fields: [postId], references: [id])

  @@index([userId])
  @@index([postId])
}

model AnimationClip {
  id          String    @id @default(cuid())
  characterId String
  type        String
  videoUrl    String
  duration    Float     @default(5.0)
  createdAt   DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id])

  @@index([characterId, type])
}

model LimitOrder {
  id                String       @id @default(cuid())
  userId            String
  characterId       String
  side              String       // "buy" or "sell"
  shares            Int
  sharesRemaining   Int          @default(0) // Unfilled portion (for partial fills in graduated phase)
  filledShares      Int          @default(0) // How many shares filled so far
  triggerPrice      Float
  lockedAmount      Float        // USDC locked (buys), 0 (sells)
  lockedAvgBuyPrice Float?       // saved from holding on sell orders for restoration on cancel
  status            String       @default("pending") // pending | partial | filled | cancelled | expired
  expiresAt         DateTime?
  filledAt          DateTime?
  cancelledAt       DateTime?
  transactionId     String?      @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user              User         @relation(fields: [userId], references: [id])
  character         Character    @relation(fields: [characterId], references: [id])
  transaction       Transaction? @relation(fields: [transactionId], references: [id])

  @@index([characterId, status])
  @@index([characterId, side, status])
  @@index([userId, status])
  @@index([status, expiresAt])
}
