generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  walletAddress String    @unique
  createdAt     DateTime  @default(now())
  holdings      Holding[]
  messages      Message[]
  payouts       Payout[]
}

model Character {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  description     String
  thumbnailUrl    String?
  personality     Json             
  // { traits: string[], catchphrases: string[], backstory: string, voiceStyle: string }
  actions         Json             
  // [{ id: string, name: string, clipUrl: string, audioUrl: string, rarity: "common"|"uncommon"|"rare"|"legendary", weight: number }]
  environment     Json             
  // { backgroundUrl: string, ambientAudioUrl: string, idleClipUrl: string }
  totalShares     Int              @default(1000000)
  sharesIssued    Int              @default(0)
  currentPrice    Float            @default(0.10)
  marketCap       Float            @default(0)
  launchAt        DateTime?
  isLaunched      Boolean          @default(false)
  tiktokHandle    String?
  instagramHandle String?
  holdings        Holding[]
  posts           Post[]
  messages        Message[]
  events          CharacterEvent[]
  transactions    Transaction[]
}

model Holding {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  shares      Int
  avgBuyPrice Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])

  @@unique([userId, characterId])
}

model Post {
  id          String    @id @default(cuid())
  characterId String
  platform    String    // "tiktok" | "instagram"
  videoUrl    String
  caption     String
  revenue     Float     @default(0)
  views       Int       @default(0)
  likes       Int       @default(0)
  paidOut     Boolean   @default(false)
  postedAt    DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id])
  payouts     Payout[]
}

model Message {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  content     String
  role        String    // "user" | "assistant"
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
}

model CharacterEvent {
  id          String    @id @default(cuid())
  characterId String
  actionId    String
  isRare      Boolean   @default(false)
  triggeredAt DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id])
}

model Transaction {
  id            String    @id @default(cuid())
  buyerId       String?
  sellerId      String?
  characterId   String
  shares        Int
  pricePerShare Float
  total         Float
  type          String    // "buy" or "sell"
  createdAt     DateTime  @default(now())
  character     Character @relation(fields: [characterId], references: [id])
}

model Payout {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  postId      String
  amount      Float
  paidAt      DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  post        Post     @relation(fields: [postId], references: [id])
}
